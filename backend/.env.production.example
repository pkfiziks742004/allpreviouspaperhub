SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# Comma-separated allowed frontend origins (no trailing slash)
FRONTEND_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PUBLIC=180
RATE_LIMIT_MAX_AUTH=360
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=20

# Upload limits
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_PDF_UPLOAD_BYTES=26214400

# Cloudinary
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Optional: server port (Cloud Run usually sets PORT automatically)
# PORT=8080

